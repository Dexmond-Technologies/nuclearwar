3. Python Prototype (Live + Historical)
import json
from statistics import stdev

# ----- Live + Historical Inputs -----
token_supply = 1_000_000
reserves = 500_000
transactions_history = [
    [100, 50, 200],  # oldest interval
    [120, 80, 150],  # recent
    [110, 60, 170]   # live
]
rewards_given = 1000
penalties_taken = 800
target_velocity = 0.02
liquidity_threshold = 0.4

# ----- Metrics -----
transactions = transactions_history[-1]  # live interval
token_velocity = sum(transactions) / token_supply
liquidity_ratio = reserves / token_supply
reward_penalty_ratio = rewards_given / max(penalties_taken, 1)
# historical volatility
all_velocity = [sum(interval)/token_supply for interval in transactions_history]
historical_volatility = stdev(all_velocity)

# ----- Stability Index -----
stability_index = 0.5*min(liquidity_ratio,1.0) + \
                  0.3*max(0,1-abs(token_velocity - target_velocity)) + \
                  0.2*min(reward_penalty_ratio,1.0)
# penalize if volatility too high
if historical_volatility > 0.05:
    stability_index *= 0.9

# ----- Connectivity -----
connectivity = {
    "wallet": "connected",
    "reward_system": "connected",
    "mining_system": "connected",
    "marketplace": "connected"
}

# ----- Recommendations -----
recommendations = []
if liquidity_ratio < liquidity_threshold:
    recommendations.append("Liquidity below threshold; consider injecting reserves.")
if abs(token_velocity - target_velocity) > 0.01:
    recommendations.append("Token velocity deviates from target; monitor transactions.")
if reward_penalty_ratio > 1.5:
    recommendations.append("Reward/Penalty ratio high; adjust distribution.")

# ----- JSON Report -----
report = {
    "connectivity": connectivity,
    "metrics": {
        "token_supply": token_supply,
        "reserves": reserves,
        "liquidity_ratio": liquidity_ratio,
        "token_velocity": token_velocity,
        "reward_penalty_ratio": reward_penalty_ratio,
        "historical_volatility": historical_volatility
    },
    "stability_index": round(stability_index, 2),
    "recommendations": recommendations
}

print(json.dumps(report, indent=2))

